# Per-tenant configuration for the public API.
# Each tenant's API key + add-on secret pair is provisioned manually at launch.
# In Phase 6 (multi-tenant self-serve) this moves to a DB.

# BRG org (single-org mode at launch)
C3_TENANT_BR_API_KEY=brg-api-key-v1
C3_TENANT_OPENCLAW_PROD_ADDON_SECRET=<base64-encoded-addon-secret>

# Optional: override the addon URL (default https://add-on.blckrbbt.io)
# C3_TENANT_OPENCLAW_PROD_ADDON_BASE=https://add-on.blckrbbt.io

# Logging
LOG_LEVEL=info
